@{
    ViewData["Title"] = "View Components";
}

<h1 class="display-6 mb-3">View Components Demo</h1>
<p>
    View components are reusable rendering units that can prepare data independently from page controllers.
</p>

<partial name="_ConceptGuideNav" />

<div class="row g-3">
    <div class="col-lg-7">
        @await Component.InvokeAsync("RecentArticles", new { count = 3 })
    </div>
    <div class="col-lg-5">
        @await Component.InvokeAsync("StatusPanel")
    </div>
</div>

<section class="mt-4">
    <h2 class="h4">Invocation styles</h2>
    <p>
        This page uses <code>@("@await Component.InvokeAsync(...)")</code>. You can also use the
        <code>&lt;vc:...&gt;</code> Tag Helper syntax for view components when preferred.
    </p>
</section>
