@{
    ViewData["Title"] = "Home Page";
}

<div class="py-3">
    <h1 class="display-5">ASP.NET Core Views Demo (.NET 10)</h1>
    <p class="lead">
        Explore partial views, view components, and Tag Helpers in a focused MVC sample.
    </p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        @await Html.PartialAsync("_FeatureCard", new FeatureCardViewModel
        {
            Title = "Partial Views",
            Description = "Reusable Razor snippets for clean and DRY page composition.",
            BadgeText = "Shared UI"
        })
    </div>
    <div class="col-md-6">
        @await Html.PartialAsync("_FeatureCard", new FeatureCardViewModel
        {
            Title = "View Components",
            Description = "Independent units that own rendering + data preparation.",
            BadgeText = "Composable"
        })
    </div>
</div>

<div class="d-flex gap-2 flex-wrap">
    <a class="btn btn-primary" asp-controller="Concepts" asp-action="Index">Open Concept Walkthrough</a>
    <a class="btn btn-outline-secondary" asp-controller="Concepts" asp-action="Documentation">Open Documentation Links</a>
</div>
